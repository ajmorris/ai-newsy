# Environment Variables for AI Newsy

# ===========================================
# SUPABASE (PostgreSQL Database)
# ===========================================
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# ===========================================
# EMAIL SERVICE (Choose one)
# ===========================================
# Option 1: Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=newsletter@yourdomain.com

# Option 2: Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ===========================================
# AI API (fallback chain)
# ===========================================
# Provider chain order (default): anthropic,gemini,openai
# LLM_PROVIDER_CHAIN=anthropic,gemini,openai
#
# Anthropic primary
ANTHROPIC_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-opus-4-6
#
# Gemini first fallback
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash
#
# OpenAI second fallback
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# ===========================================
# AI PROMPTS (optional overrides)
# ===========================================
# These are optional. If not set, scripts use built-in defaults.
# Set in GitHub Secrets for the daily digest workflow.

# Summarization prompt (used by summarize_articles.py)
# Voice target: first-person, candid "coffee conversation" take.
# Should sound like lived observations ("what I'm learning/watching/seeing"),
# not detached analyst commentary.
# PROMPT_SUMMARIZE=You are writing my daily AI digest in my voice...

# Topic classification prompt (used by assign_topics.py)
# PROMPT_TOPIC=You are classifying AI news articles...

# Daily intro paragraph prompt (used by send_daily_email.py/build_digest_markdown.py)
# Voice target: a personal "message from me" intro (2-3 sentences),
# warm and honest, with no hype or guru certainty.
# PROMPT_INTRO=You are writing the opening paragraph for my daily AI digest...

# Single-pass analysis lookback window in hours (used by analyze_articles_single_pass.py)
# SINGLE_PASS_WINDOW_HOURS=48

# ===========================================
# APP CONFIG
# ===========================================
# Your deployed Vercel URL (for email links)
APP_URL=https://your-app.vercel.app

# Digest: max articles per source (default 2)
# DIGEST_MAX_PER_SOURCE=2

# Topic-based digest: don't repeat a topic within this many days (default 5)
# DIGEST_TOPIC_COOLDOWN_DAYS=5

# Cleanup: delete articles older than this many days (default 30; used by cleanup_old_articles.py and GitHub Action)
# ARTICLE_RETENTION_DAYS=30

# Secret for generating confirmation tokens
TOKEN_SECRET=generate-a-random-32-char-string

# ===========================================
# SIGNUP API PROTECTION (optional but recommended)
# ===========================================
# Vercel API routes now use SUPABASE_SECRET_KEY (server-side only).
# Optional anti-abuse controls for frontend/api/subscribe.js:
#
# Rate limiting (per IP, in-memory fallback for serverless runtime)
# SUBSCRIBE_RATE_LIMIT_WINDOW_MS=600000
# SUBSCRIBE_RATE_LIMIT_MAX_REQUESTS=5
#
# Captcha: configure one provider with both SITE_KEY + SECRET_KEY.
# If only a secret is set and the frontend cannot load captcha, subscribe falls back
# to honeypot + rate limiting (fail-open) and logs a warning server-side.
# Cloudflare Turnstile:
# TURNSTILE_SITE_KEY=0x4AAAA...
# TURNSTILE_SECRET_KEY=0x4AAAA...
#
# hCaptcha:
# HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
# HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# ===========================================
# NOTIFICATIONS
# ===========================================
# Slack Incoming Webhook URL for new newsletter signup alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
